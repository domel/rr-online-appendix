@prefix rr: <https://w3id.org/rapid-review/graph-schema/ontology#> .
@prefix inst: <https://w3id.org/rapid-review/graph-schema/instance/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dct: <http://purl.org/dc/terms/> .

rr:GraphSchemaRapidReviewOntology a owl:Ontology ;
  dct:title "Graph Schema Rapid Review Ontology" ;
  dct:description "Ontology induced from 83 rapid-review records on schema languages and integrity constraints for graph databases." ;
  dct:created "2026-03-01"^^xsd:date ;
  dct:source "rr_data_extraction_filled.csv" .

### Core classes
rr:Publication a owl:Class ; rdfs:label "Publication" .
rr:ApproachFamily a owl:Class ; rdfs:label "Approach family" .
rr:ApproachSubClass a owl:Class ; rdfs:label "Approach subclass" .
rr:ModelTarget a owl:Class ; rdfs:label "Model target" .
rr:Mechanism a owl:Class ; rdfs:label "Language/mechanism" .
rr:SupportLevel a owl:Class ; rdfs:label "Support level" .

### Object properties
rr:hasApproachFamily a owl:ObjectProperty, owl:FunctionalProperty ;
  rdfs:domain rr:Publication ; rdfs:range rr:ApproachFamily ; rdfs:label "has approach family" .
rr:hasApproachSubClass a owl:ObjectProperty, owl:FunctionalProperty ;
  rdfs:domain rr:Publication ; rdfs:range rr:ApproachSubClass ; rdfs:label "has approach subclass" .
rr:targetsModel a owl:ObjectProperty, owl:FunctionalProperty ;
  rdfs:domain rr:Publication ; rdfs:range rr:ModelTarget ; rdfs:label "targets model" .
rr:usesMechanism a owl:ObjectProperty, owl:FunctionalProperty ;
  rdfs:domain rr:Publication ; rdfs:range rr:Mechanism ; rdfs:label "uses mechanism" .
rr:belongsToFamily a owl:ObjectProperty ;
  rdfs:domain rr:ApproachSubClass ; rdfs:range rr:ApproachFamily ; rdfs:label "belongs to family" .

rr:hasTypingNodeSupport a owl:ObjectProperty ; rdfs:domain rr:Publication ; rdfs:range rr:SupportLevel .
rr:hasCardinalitySupport a owl:ObjectProperty ; rdfs:domain rr:Publication ; rdfs:range rr:SupportLevel .
rr:hasValueConstraintSupport a owl:ObjectProperty ; rdfs:domain rr:Publication ; rdfs:range rr:SupportLevel .
rr:hasKeySupport a owl:ObjectProperty ; rdfs:domain rr:Publication ; rdfs:range rr:SupportLevel .
rr:hasPathConstraintSupport a owl:ObjectProperty ; rdfs:domain rr:Publication ; rdfs:range rr:SupportLevel .
rr:hasRecursionSupport a owl:ObjectProperty ; rdfs:domain rr:Publication ; rdfs:range rr:SupportLevel .
rr:hasImplementationSupport a owl:ObjectProperty ; rdfs:domain rr:Publication ; rdfs:range rr:SupportLevel .
rr:hasEvaluationSupport a owl:ObjectProperty ; rdfs:domain rr:Publication ; rdfs:range rr:SupportLevel .

### Datatype properties
rr:recordId a owl:DatatypeProperty ; rdfs:domain rr:Publication ; rdfs:range xsd:string .
rr:title a owl:DatatypeProperty ; rdfs:domain rr:Publication ; rdfs:range xsd:string .
rr:publicationYear a owl:DatatypeProperty ; rdfs:domain rr:Publication ; rdfs:range xsd:gYear .
rr:venue a owl:DatatypeProperty ; rdfs:domain rr:Publication ; rdfs:range xsd:string .
rr:publicationType a owl:DatatypeProperty ; rdfs:domain rr:Publication ; rdfs:range xsd:string .
rr:doi a owl:DatatypeProperty ; rdfs:domain rr:Publication ; rdfs:range xsd:string .
rr:url a owl:DatatypeProperty ; rdfs:domain rr:Publication ; rdfs:range xsd:anyURI .
rr:qualityTheoryScore a owl:DatatypeProperty ; rdfs:domain rr:Publication ; rdfs:range xsd:integer .
rr:qualitySystemScore a owl:DatatypeProperty ; rdfs:domain rr:Publication ; rdfs:range xsd:integer .

### Axioms
rr:Publication rdfs:subClassOf
  [ a owl:Restriction ; owl:onProperty rr:hasApproachFamily ; owl:someValuesFrom rr:ApproachFamily ],
  [ a owl:Restriction ; owl:onProperty rr:hasApproachSubClass ; owl:someValuesFrom rr:ApproachSubClass ],
  [ a owl:Restriction ; owl:onProperty rr:targetsModel ; owl:someValuesFrom rr:ModelTarget ],
  [ a owl:Restriction ; owl:onProperty rr:usesMechanism ; owl:someValuesFrom rr:Mechanism ] .

### Support levels
rr:YesSupport a rr:SupportLevel ; rdfs:label "Yes" .
rr:PartialSupport a rr:SupportLevel ; rdfs:label "Partial" .
rr:MixedSupport a rr:SupportLevel ; rdfs:label "Mixed" .
rr:NoSupport a rr:SupportLevel ; rdfs:label "No" .
rr:NotSpecifiedSupport a rr:SupportLevel ; rdfs:label "Not specified" .

### Approach family individuals
rr:SemanticSchemaFamily a rr:ApproachFamily ; rdfs:label "Semantic schema" .
rr:ShapesConstraintsFamily a rr:ApproachFamily ; rdfs:label "Shapes / constraints" .
rr:DependenciesICFamily a rr:ApproachFamily ; rdfs:label "Dependencies / IC" .
rr:GraphQLReferenceFamily a rr:ApproachFamily ; rdfs:label "GraphQL reference" .
rr:OtherUnknownFamily a rr:ApproachFamily ; rdfs:label "Other / unknown" .

### Model target individuals
rr:RDFTarget a rr:ModelTarget ; rdfs:label "RDF" .
rr:PropertyGraphTarget a rr:ModelTarget ; rdfs:label "Property graphs" .
rr:GraphQLTarget a rr:ModelTarget ; rdfs:label "GraphQL" .
rr:OtherUnknownTarget a rr:ModelTarget ; rdfs:label "Other / unknown" .

### Corpus individual
inst:Corpus83 a rr:Publication ;
  rr:recordId "CORPUS" ;
  rr:title "Rapid review corpus aggregate" ;
  rr:publicationYear "2026"^^xsd:gYear ;
  rr:venue "Derived from rr_data_extraction_filled.csv" ;
  rr:publicationType "DatasetAggregate" .

